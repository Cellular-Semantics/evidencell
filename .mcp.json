{
  "mcpServers": {
    "Asta_semanticscholar": {
      "type": "http",
      "url": "https://asta-tools.allen.ai/mcp/v1",
      "headers": { "x-api-key": "${ASTA_API_KEY}" },
      "tools": ["*"]
    },
    "artl-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["artl-mcp"]
    },
      "ols4": {
      "type": "http",
      "url": "https://wwwdev.ebi.ac.uk/ols4/api/mcp",
      "tools": ["*"]
    }
  }
}